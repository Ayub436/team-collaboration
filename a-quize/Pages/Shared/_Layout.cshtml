<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Realtime Quiz</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <a class="brand" asp-page="/Index">Realtime Quiz</a>
        <nav>
            <a asp-page="/Login">Host</a>
            <a asp-page="/StudentLogin">Student Login</a>
            <a asp-page="/Quizzes">Quizzes</a>
        </nav>
    </header>

    <main class="shell">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
