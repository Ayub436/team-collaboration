@page
@model RealtimeQuiz.Pages.LoginModel
@{
    ViewData["Title"] = "Host Login";
}

<section class="center-panel">
    <div class="panel">
        <p class="eyebrow">Admin</p>
        <h1>Host login</h1>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="notice error">@Model.Message</div>
        }

        <form method="post" class="stack">
            <label>
                Host password
                <input asp-for="Input.Password" type="password" placeholder="Enter host password" />
            </label>
            <button class="button primary" type="submit">Login</button>
        </form>
    </div>
</section>
